# StreamSpin Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to git.

# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
HOST=127.0.0.1

# ── Webhook Trigger ──────────────────────────────────────────────────────────
# A random secret string used to authenticate POST /api/trigger requests.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
WEBHOOK_SECRET=replace_me_with_a_random_string

# ── Twitch ───────────────────────────────────────────────────────────────────
# Your Twitch application credentials (register at dev.twitch.tv)
TWITCH_CLIENT_ID=
TWITCH_CLIENT_SECRET=

# The channel you want to read chat from (your streamer account username)
TWITCH_CHANNEL=

# OAuth callback URL — must match what you set in dev.twitch.tv
TWITCH_REDIRECT_URI=http://localhost:3000/auth/twitch/callback

# Populated automatically after first OAuth login — do not set manually
TWITCH_ACCESS_TOKEN=
TWITCH_REFRESH_TOKEN=
TWITCH_BROADCASTER_ID=

# ── Kick ─────────────────────────────────────────────────────────────────────
# Kick channel slug (the part after kick.com/)
# e.g. for kick.com/xqc → KICK_CHANNEL=xqc
KICK_CHANNEL=

# Kick's Pusher app key (public — used to connect to their WebSocket)
# This is a public value; you can find it in Kick's web app network traffic.
KICK_PUSHER_APP_KEY=32cbd69e4b950bf97679
KICK_PUSHER_CLUSTER=us2

# ── OnlyFans ─────────────────────────────────────────────────────────────────
# No official API is available. Use the manual webhook trigger above.
# Future: populate when an official API is released.
# ONLYFANS_API_KEY=
