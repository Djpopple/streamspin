{
  "version": 1,
  "wheel": {
    "backgroundColor": "transparent",
    "borderWidth": 4,
    "borderColor": "#ffffff",
    "hubSize": 20,
    "hubColor": "#ffffff",
    "globalFont": "Bangers, cursive",
    "globalFontSize": 22,
    "glowEnabled": false,
    "glowColor": "#ffffff",
    "glowIntensity": 10,
    "shadowEnabled": true,
    "framePadding": 48,
    "frameEnabled": false,
    "labelBold": false,
    "labelItalic": false,
    "segmentImageMode": "none",
    "segmentImageOpacity": 1,
    "segmentImageOverlay": 0.35
  },
  "segments": [
    { "id": "1", "label": "BOOM",   "color": "#f97316", "textColor": "#ffffff", "weight": 1, "enabled": true },
    { "id": "2", "label": "MISS",   "color": "#1e1e2e", "textColor": "#f97316", "weight": 2, "enabled": true },
    { "id": "3", "label": "KABAM",  "color": "#e94560", "textColor": "#ffffff", "weight": 1, "enabled": true },
    { "id": "4", "label": "MISS",   "color": "#1e1e2e", "textColor": "#e94560", "weight": 2, "enabled": true },
    { "id": "5", "label": "POW",    "color": "#eab308", "textColor": "#000000", "weight": 1, "enabled": true },
    { "id": "6", "label": "MISS",   "color": "#1e1e2e", "textColor": "#eab308", "weight": 2, "enabled": true },
    { "id": "7", "label": "WHAM",   "color": "#22c55e", "textColor": "#000000", "weight": 1, "enabled": true },
    { "id": "8", "label": "MISS",   "color": "#1e1e2e", "textColor": "#22c55e", "weight": 2, "enabled": true }
  ],
  "pointer": {
    "preset": "pin",
    "position": "top",
    "scale": 1.3
  },
  "spin": {
    "durationMin": 2500,
    "durationMax": 5500,
    "rotationsMin": 7,
    "rotationsMax": 15,
    "easing": "ease-out-quint",
    "bounce": true,
    "bounceIntensity": 0.55
  },
  "result": {
    "enabled": true,
    "duration": 3500,
    "lingerDuration": 0,
    "messageTemplate": "💥 {winner}! 💥",
    "backgroundColor": "#000000",
    "backgroundOpacity": 0.8,
    "font": "Bangers, cursive",
    "fontSize": 60,
    "textColor": "#f97316"
  },
  "sound": {
    "spinStartEnabled": false,
    "spinStartVolume": 0.8,
    "winEnabled": false,
    "winVolume": 0.8
  },
  "commands": [
    { "name": "spin", "trigger": "!spin", "enabled": true, "cooldownSeconds": 30, "modOnly": false, "broadcasterOnly": false, "response": "The wheel is spinning! 🎡" },
    { "name": "addslice", "trigger": "!addslice", "enabled": true, "cooldownSeconds": 0, "modOnly": true, "broadcasterOnly": false, "response": "" },
    { "name": "removeslice", "trigger": "!removeslice", "enabled": true, "cooldownSeconds": 0, "modOnly": true, "broadcasterOnly": false, "response": "" }
  ],
  "removeWinnerMode": false,
  "integrations": {
    "twitch": { "enabled": false, "channel": "", "botUsername": "", "channelPointsEnabled": false },
    "kick": { "enabled": false, "botrixSetupComplete": false },
    "webhook": { "enabled": true }
  }
}
